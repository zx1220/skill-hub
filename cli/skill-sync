#!/usr/bin/env node
/**
 * skill-sync — CLI tool to sync Claude Code skills with a Skill Hub server.
 *
 * Usage:
 *   skill-sync auth <server-url> <api-key>              Save credentials
 *   skill-sync push <skill-name> [--force]              Push local skill to server
 *   skill-sync push --all                               Push all local skills
 *   skill-sync pull [skill-name]                        Pull skill(s) from server
 *   skill-sync list                                     List skills on server
 *   skill-sync install <skill-name>                     Install skill to local dir
 *   skill-sync status                                   Show server status
 *   skill-sync migrate --from-github --repo <r> --token <t>
 *                                                        Import skills from GitHub
 */

const fs = require("fs");
const path = require("path");
const http = require("http");
const https = require("https");
const crypto = require("crypto");

// ─── Config ───
const CONFIG_PATH = path.join(process.env.HOME, ".skill-hub.json");

function loadConfig() {
  try {
    return JSON.parse(fs.readFileSync(CONFIG_PATH, "utf-8"));
  } catch {
    return {};
  }
}

function saveConfig(config) {
  fs.writeFileSync(CONFIG_PATH, JSON.stringify(config, null, 2));
}

const CLAUDE_SKILLS_DIR = path.join(process.env.HOME, ".claude", "skills");

// ─── HTTP helper ───
function httpRequest(url, options) {
  options = options || {};
  return new Promise(function (resolve, reject) {
    var parsedUrl = new URL(url);
    var mod = parsedUrl.protocol === "https:" ? https : http;

    var opts = {
      hostname: parsedUrl.hostname,
      port: parsedUrl.port || (parsedUrl.protocol === "https:" ? 443 : 80),
      path: parsedUrl.pathname + parsedUrl.search,
      method: options.method || "GET",
      headers: Object.assign(
        {
          "Content-Type": "application/json",
          "User-Agent": "skill-sync/2.0",
        },
        options.headers || {}
      ),
    };

    var req = mod.request(opts, function (res) {
      var data = "";
      res.on("data", function (chunk) {
        data += chunk;
      });
      res.on("end", function () {
        try {
          var parsed = JSON.parse(data);
          resolve({ status: res.statusCode, data: parsed });
        } catch {
          resolve({ status: res.statusCode, data: data });
        }
      });
    });

    req.on("error", reject);
    if (options.body) req.write(JSON.stringify(options.body));
    req.end();
  });
}

function getAuthHeaders() {
  var config = loadConfig();
  if (!config.api_key) {
    console.error("Error: Not authenticated. Run: skill-sync auth <server-url> <api-key>");
    process.exit(1);
  }
  return { Authorization: "Bearer " + config.api_key };
}

function getServerUrl() {
  var config = loadConfig();
  if (!config.server_url) {
    console.error("Error: No server configured. Run: skill-sync auth <server-url> <api-key>");
    process.exit(1);
  }
  return config.server_url.replace(/\/$/, "");
}

// ─── Checksum ───
function computeChecksum(files) {
  var content = files
    .map(function (f) {
      return f.filename + ":" + f.content;
    })
    .sort()
    .join("\n");
  return crypto.createHash("sha256").update(content).digest("hex").slice(0, 16);
}

// ─── Commands ───

async function auth(serverUrl, apiKey) {
  var url = serverUrl.replace(/\/$/, "") + "/api/sync/status";
  try {
    var res = await httpRequest(url, {
      headers: { Authorization: "Bearer " + apiKey },
    });
    if (res.status !== 200) {
      console.error("Error: Invalid API key or server unreachable");
      process.exit(1);
    }
  } catch (e) {
    console.error("Error: Cannot connect to server: " + e.message);
    process.exit(1);
  }

  saveConfig({ server_url: serverUrl.replace(/\/$/, ""), api_key: apiKey });
  console.log("✓ Credentials saved to ~/.skill-hub.json");
}

async function pushSkill(skillName, force) {
  var skillDir = path.join(CLAUDE_SKILLS_DIR, skillName);
  if (!fs.existsSync(skillDir)) {
    console.error("Error: Skill directory not found: " + skillDir);
    process.exit(1);
  }

  var files = [];
  fs.readdirSync(skillDir).forEach(function (file) {
    var filePath = path.join(skillDir, file);
    var stat = fs.statSync(filePath);
    if (stat.isFile()) {
      files.push({ filename: file, content: fs.readFileSync(filePath, "utf-8") });
    }
  });

  if (files.length === 0) {
    console.error("Error: No files found in " + skillDir);
    process.exit(1);
  }

  var checksum = computeChecksum(files);

  // Load last known server checksum
  var baseChecksum;
  if (!force) {
    var lockPath = path.join(CLAUDE_SKILLS_DIR, ".skills_store_lock.json");
    try {
      var lock = JSON.parse(fs.readFileSync(lockPath, "utf-8"));
      if (lock.skills && lock.skills[skillName]) {
        baseChecksum = lock.skills[skillName].server_checksum;
      }
    } catch {
      // No lock file, first push
    }
  }

  console.log("Pushing " + skillName + " (" + files.length + " files)...");

  var url = getServerUrl() + "/api/sync/push";
  var res = await httpRequest(url, {
    method: "POST",
    headers: getAuthHeaders(),
    body: {
      slug: skillName,
      files: files,
      checksum: checksum,
      base_checksum: baseChecksum,
    },
  });

  if (res.status === 409) {
    console.error("Conflict: Server version differs. Use --force to overwrite.");
    process.exit(1);
  }
  if (res.status !== 200) {
    console.error("Error: " + (res.data && res.data.error ? res.data.error : "HTTP " + res.status));
    process.exit(1);
  }

  // Save server checksum for future sync
  var lockPath2 = path.join(CLAUDE_SKILLS_DIR, ".skills_store_lock.json");
  var lock2 = {};
  try {
    lock2 = JSON.parse(fs.readFileSync(lockPath2, "utf-8"));
  } catch {
    lock2 = { skills: {} };
  }
  if (!lock2.skills) lock2.skills = {};
  lock2.skills[skillName] = {
    server_checksum: res.data.checksum,
    last_sync: new Date().toISOString(),
  };
  fs.writeFileSync(lockPath2, JSON.stringify(lock2, null, 2));

  console.log("✓ Pushed " + skillName + " (checksum: " + res.data.checksum + ")");
}

async function pushAll(force) {
  if (!fs.existsSync(CLAUDE_SKILLS_DIR)) {
    console.error("Error: No skills directory found at ~/.claude/skills/");
    process.exit(1);
  }

  var dirs = fs.readdirSync(CLAUDE_SKILLS_DIR).filter(function (name) {
    var p = path.join(CLAUDE_SKILLS_DIR, name);
    return fs.statSync(p).isDirectory() && !name.startsWith(".");
  });

  if (dirs.length === 0) {
    console.log("No skills found locally.");
    return;
  }

  console.log("Pushing " + dirs.length + " skills...\n");
  for (var i = 0; i < dirs.length; i++) {
    try {
      await pushSkill(dirs[i], force);
    } catch (e) {
      console.error("  ✗ " + dirs[i] + ": " + e.message);
    }
  }
  console.log("\nDone!");
}

async function pullSkills(skillName) {
  var serverUrl = getServerUrl();
  var headers = getAuthHeaders();

  // Get last sync timestamp
  var since;
  var lockPath = path.join(CLAUDE_SKILLS_DIR, ".skills_store_lock.json");
  try {
    var lock = JSON.parse(fs.readFileSync(lockPath, "utf-8"));
    since = lock.last_full_sync;
  } catch {
    // No previous sync, pull everything
  }

  var url = serverUrl + "/api/sync/pull" + (since ? "?since=" + since : "");
  var res = await httpRequest(url, { headers: headers });

  if (res.status !== 200) {
    console.error("Error: " + (res.data && res.data.error ? res.data.error : "HTTP " + res.status));
    process.exit(1);
  }

  var changes = res.data.changes;
  if (changes.length === 0) {
    console.log("Already up to date.");
    return;
  }

  // Filter by skill name if specified
  var filtered = skillName ? changes.filter(function (c) { return c.slug === skillName; }) : changes;

  if (skillName && filtered.length === 0) {
    console.error('Error: Skill "' + skillName + '" not found on server.');
    process.exit(1);
  }

  console.log("Pulling " + filtered.length + " skill(s)...\n");

  if (!fs.existsSync(CLAUDE_SKILLS_DIR)) {
    fs.mkdirSync(CLAUDE_SKILLS_DIR, { recursive: true });
  }

  for (var i = 0; i < filtered.length; i++) {
    var change = filtered[i];
    var skillDir = path.join(CLAUDE_SKILLS_DIR, change.slug);

    if (change.action === "delete") {
      if (fs.existsSync(skillDir)) {
        fs.rmSync(skillDir, { recursive: true, force: true });
        console.log("  ✓ Deleted " + change.slug);
      }
      continue;
    }

    if (!fs.existsSync(skillDir)) {
      fs.mkdirSync(skillDir, { recursive: true });
    }

    // Remove old files not in the new set
    var newFilenames = new Set(change.files.map(function (f) { return f.filename; }));
    fs.readdirSync(skillDir).forEach(function (existing) {
      if (!newFilenames.has(existing)) {
        fs.rmSync(path.join(skillDir, existing), { force: true });
      }
    });

    for (var j = 0; j < change.files.length; j++) {
      var file = change.files[j];
      fs.writeFileSync(path.join(skillDir, file.filename), file.content, "utf-8");
    }
    console.log("  ✓ " + change.slug + " (" + change.files.length + " files)");
  }

  // Update sync cursor
  var lock3 = {};
  try {
    lock3 = JSON.parse(fs.readFileSync(lockPath, "utf-8"));
  } catch {
    lock3 = { skills: {} };
  }
  lock3.last_full_sync = res.data.server_time;
  for (var k = 0; k < filtered.length; k++) {
    if (!lock3.skills) lock3.skills = {};
    lock3.skills[filtered[k].slug] = {
      server_checksum: filtered[k].checksum,
      last_sync: res.data.server_time,
    };
  }
  fs.writeFileSync(lockPath, JSON.stringify(lock3, null, 2));

  console.log("\nDone!");
}

async function listSkills() {
  var serverUrl = getServerUrl();
  var res = await httpRequest(serverUrl + "/api/skills");

  if (res.status !== 200) {
    console.error("Error: " + (res.data && res.data.error ? res.data.error : "HTTP " + res.status));
    process.exit(1);
  }

  var skills = res.data.skills;
  if (!skills || skills.length === 0) {
    console.log("No skills found on server.");
    return;
  }

  console.log("\n  Skills on server (" + skills.length + "):\n");
  console.log("  " + pad("Name", 25) + " " + pad("Slug", 20) + " Description");
  console.log("  " + "─".repeat(25) + " " + "─".repeat(20) + " " + "─".repeat(40));
  for (var i = 0; i < skills.length; i++) {
    var skill = skills[i];
    console.log(
      "  " + pad(skill.name || "", 25) + " " + pad(skill.slug, 20) + " " + (skill.description || "").slice(0, 40)
    );
  }
  console.log();
}

function pad(str, len) {
  while (str.length < len) str += " ";
  return str;
}

async function installSkill(skillName) {
  console.log("Installing " + skillName + "...");
  await pullSkills(skillName);
  console.log("Installed to ~/.claude/skills/" + skillName + "/");
}

async function showStatus() {
  var serverUrl = getServerUrl();
  var headers = getAuthHeaders();
  var res = await httpRequest(serverUrl + "/api/sync/status", { headers: headers });

  if (res.status !== 200) {
    console.error("Error: " + (res.data && res.data.error ? res.data.error : "HTTP " + res.status));
    process.exit(1);
  }

  var d = res.data;
  console.log("\n  Skill Hub Server: " + serverUrl);
  console.log("  Skills:           " + d.skill_count);
  console.log("  Last modified:    " + (d.last_modified || "never"));
  console.log("  Server time:      " + d.server_time + "\n");
}

async function migrateFromGitHub(repo, token) {
  if (!repo || !token) {
    console.error("Usage: skill-sync migrate --from-github --repo <owner/repo> --token <gh-token>");
    process.exit(1);
  }

  var serverUrl = getServerUrl();
  var headers = getAuthHeaders();

  console.log("Fetching skills from GitHub repo: " + repo + "...");

  var ghRes = await httpRequest("https://api.github.com/repos/" + repo + "/contents/skills", {
    headers: {
      Authorization: "Bearer " + token,
      Accept: "application/vnd.github.v3+json",
      "User-Agent": "skill-sync",
    },
  });

  if (ghRes.status !== 200 || !Array.isArray(ghRes.data)) {
    console.error("Error: Could not list skills from GitHub");
    process.exit(1);
  }

  var dirs = ghRes.data.filter(function (item) { return item.type === "dir"; });
  console.log("Found " + dirs.length + " skill(s).\n");

  for (var i = 0; i < dirs.length; i++) {
    var slug = dirs[i].name;
    console.log("  Migrating " + slug + "...");

    var filesRes = await httpRequest(
      "https://api.github.com/repos/" + repo + "/contents/skills/" + slug,
      {
        headers: {
          Authorization: "Bearer " + token,
          Accept: "application/vnd.github.v3+json",
          "User-Agent": "skill-sync",
        },
      }
    );

    if (filesRes.status !== 200 || !Array.isArray(filesRes.data)) {
      console.error("    ✗ Could not list files for " + slug);
      continue;
    }

    var files = [];
    for (var j = 0; j < filesRes.data.length; j++) {
      var f = filesRes.data[j];
      if (f.type !== "file") continue;
      var fileRes = await httpRequest(
        "https://api.github.com/repos/" + repo + "/contents/skills/" + slug + "/" + f.name,
        {
          headers: {
            Authorization: "Bearer " + token,
            Accept: "application/vnd.github.v3+json",
            "User-Agent": "skill-sync",
          },
        }
      );
      if (fileRes.status === 200 && fileRes.data.content) {
        var content = Buffer.from(fileRes.data.content, "base64").toString("utf-8");
        files.push({ filename: f.name, content: content });
      }
    }

    if (files.length === 0) {
      console.error("    ✗ No files found for " + slug);
      continue;
    }

    var checksum = computeChecksum(files);

    var pushRes = await httpRequest(serverUrl + "/api/sync/push", {
      method: "POST",
      headers: headers,
      body: { slug: slug, files: files, checksum: checksum },
    });

    if (pushRes.status === 200) {
      console.log("    ✓ Migrated " + slug + " (" + files.length + " files)");
    } else {
      console.error("    ✗ Failed: " + (pushRes.data && pushRes.data.error ? pushRes.data.error : "HTTP " + pushRes.status));
    }
  }

  console.log("\nMigration complete!");
}

// ─── CLI Router ───

var args = process.argv.slice(2);
var command = args[0];

function hasFlag(flag) {
  return args.indexOf(flag) !== -1;
}

function getOption(name) {
  var idx = args.indexOf(name);
  if (idx !== -1 && args[idx + 1]) return args[idx + 1];
  return undefined;
}

(async function () {
  switch (command) {
    case "auth": {
      var serverUrl = args[1];
      var apiKey = args[2];
      if (!serverUrl || !apiKey) {
        console.error("Usage: skill-sync auth <server-url> <api-key>");
        process.exit(1);
      }
      await auth(serverUrl, apiKey);
      break;
    }
    case "push": {
      if (hasFlag("--all")) {
        await pushAll(hasFlag("--force"));
      } else {
        var name = args[1];
        if (!name || name.startsWith("-")) {
          console.error("Usage: skill-sync push <skill-name> [--force]");
          console.error("       skill-sync push --all [--force]");
          process.exit(1);
        }
        await pushSkill(name, hasFlag("--force"));
      }
      break;
    }
    case "pull": {
      var skillName = args[1] && !args[1].startsWith("-") ? args[1] : undefined;
      await pullSkills(skillName);
      break;
    }
    case "list": {
      await listSkills();
      break;
    }
    case "install": {
      var installName = args[1];
      if (!installName) {
        console.error("Usage: skill-sync install <skill-name>");
        process.exit(1);
      }
      await installSkill(installName);
      break;
    }
    case "status": {
      await showStatus();
      break;
    }
    case "migrate": {
      if (hasFlag("--from-github")) {
        await migrateFromGitHub(getOption("--repo"), getOption("--token"));
      } else {
        console.error("Usage: skill-sync migrate --from-github --repo <owner/repo> --token <gh-token>");
        process.exit(1);
      }
      break;
    }
    default:
      console.log(
        "\n  skill-sync — Skill Hub CLI v2.0\n" +
          "\n  Commands:\n" +
          "    auth <server-url> <api-key>                     Save credentials\n" +
          "    push <name> [--force]                           Push skill to server\n" +
          "    push --all [--force]                            Push all local skills\n" +
          "    pull [name]                                     Pull skill(s) from server\n" +
          "    list                                            List skills on server\n" +
          "    install <name>                                  Install skill locally\n" +
          "    status                                          Show server status\n" +
          "    migrate --from-github --repo <r> --token <t>    Import from GitHub\n"
      );
  }
})();
