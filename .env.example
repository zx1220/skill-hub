# Skill Hub 配置。所有变量均可选——全留空也能用本地模式启动。
# 数据源是 libSQL（src/lib/db.ts），不再是 GitHub 仓库。

# ─── 数据库 (libSQL / Turso) ─────────────────────────────
# 留空 → 使用本地 ./data/local.db（开箱即用，本地开发）
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── 认证 ────────────────────────────────────────────────
# 生产(serverless)必填；留空 → 本地 ./data/.master-key 自动生成并打印
SKILL_MASTER_KEY=

# ─── 预留（当前未启用）──────────────────────────────────
# 分类走关键词规则（src/lib/classify.ts），此 key 暂未被使用
ANTHROPIC_API_KEY=

# ─── 迁移脚本专用 (scripts/migrate-to-turso.ts) ─────────
# 旧 better-sqlite3 源库路径，默认 data/skill-hub.db
# SRC_DB=
