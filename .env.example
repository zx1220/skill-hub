# Skill Hub 配置。
# 数据源是 Supabase Postgres（src/lib/db.ts，postgres.js 客户端）。

# ─── 数据库 (Supabase Postgres) ─────────────────────────
# 必填。Supabase Dashboard → Project Settings → Database → Connection string → URI（Transaction mode :6543）
# 本地开发也必须配置（已无本地文件 fallback）
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ─── 认证 ────────────────────────────────────────────────
# 生产(serverless)必填；留空 → 本地 ./data/.master-key 自动生成并打印
SKILL_MASTER_KEY=

# ─── 预留（当前未启用）──────────────────────────────────
# 分类走关键词规则（src/lib/classify.ts），此 key 暂未被使用
ANTHROPIC_API_KEY=

# ─── 数据迁移脚本 (scripts/migrate-to-supabase.ts) ──────
# 一次性把本地 libSQL (data/local.db) 灌入 Supabase，复用上面的 SUPABASE_DB_URL。
# 用法：bun run migrate:supabase（加 RESET=1 先 TRUNCATE 目标表再全量灌入）
